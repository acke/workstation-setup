#!/usr/bin/env bash
# Sync bastiandoetsch/skills-and-agents into ~/.claude and ~/.cursor as symlinks.
# Precedence: snyk/ide-tools wins. A Bastian skill/agent is only linked if no
# target with that name already exists. Re-run safely; idempotent.
#
# Layout (Bastian):
#   skills/<name>/SKILL.md   -> ~/.claude/skills/<name> + ~/.cursor/skills/<name>
#   agents/<name>.md         -> ~/.claude/agents/<name>.md  (Cursor doesn't read this)
#
# Env:
#   BASTIAN_SKILLS_REPO       path to clone (default: ~/repos/bastian-skills)
#   BASTIAN_SYNC_PULL=0       skip the git pull step (default: 1 = pull)
#   BASTIAN_SYNC_VERBOSE=1    log every link/skip
#   BASTIAN_SYNC_SUMMARY=0    suppress the summary line

set -u

REPO="${BASTIAN_SKILLS_REPO:-$HOME/repos/bastian-skills}"
CLAUDE_SKILLS="$HOME/.claude/skills"
CURSOR_SKILLS="$HOME/.cursor/skills"
CLAUDE_AGENTS="$HOME/.claude/agents"

VERBOSE="${BASTIAN_SYNC_VERBOSE:-0}"
SUMMARY="${BASTIAN_SYNC_SUMMARY:-1}"
LINKED=0
SKIPPED=0
REMOVED=0

# Snyk skill names to deactivate because Bastian's equivalent (under a different
# name) is preferred. Removes the snyk symlinks from ~/.claude/skills and
# ~/.cursor/skills after the link pass. Re-run safe.
OVERRIDDEN_SNYK_SKILLS=(
  "implementation"               # use bastian/impl-core instead
  "create-implementation-plan"   # use bastian/plan-core instead
)

log()  { [ "$VERBOSE" = "1" ] && printf '%s\n' "$*" >&2; return 0; }
warn() { printf 'external-skills-sync: %s\n' "$*" >&2; }

[ -d "$REPO" ] || { warn "missing $REPO"; exit 0; }

# Pull latest from remote before linking (set BASTIAN_SYNC_PULL=0 to skip).
if [ "${BASTIAN_SYNC_PULL:-1}" = "1" ] && [ -e "$REPO/.git" ]; then
  if git -C "$REPO" pull --ff-only --quiet 2>/dev/null; then
    log "pulled latest in $REPO"
  else
    log "pull skipped or failed in $REPO (offline, dirty tree, or non-ff)"
  fi
fi

mkdir -p "$CLAUDE_SKILLS" "$CURSOR_SKILLS" "$CLAUDE_AGENTS"

# link_one <src> <dst>
# Symlink src -> dst. If dst already exists and is not our symlink, skip (snyk wins).
link_one() {
  local src="$1" dst="$2"
  if [ -L "$dst" ]; then
    if [ "$(readlink "$dst")" = "$src" ]; then
      log "ok:    $dst"
      return 0
    fi
    log "skip:  $dst (other symlink — snyk wins)"
    SKIPPED=$((SKIPPED + 1))
    return 0
  fi
  if [ -e "$dst" ]; then
    log "skip:  $dst (real file/dir — snyk wins)"
    SKIPPED=$((SKIPPED + 1))
    return 0
  fi
  ln -s "$src" "$dst"
  LINKED=$((LINKED + 1))
  log "link:  $dst -> $src"
}

# Skills (Claude + Cursor)
if [ -d "$REPO/skills" ]; then
  for d in "$REPO/skills"/*/; do
    [ -d "$d" ] || continue
    [ -f "${d}SKILL.md" ] || continue
    name="$(basename "$d")"
    src="${d%/}"
    link_one "$src" "$CLAUDE_SKILLS/$name"
    link_one "$src" "$CURSOR_SKILLS/$name"
  done
fi

# Agents (Claude only)
if [ -d "$REPO/agents" ]; then
  for f in "$REPO/agents"/*.md; do
    [ -f "$f" ] || continue
    name="$(basename "$f")"
    link_one "$f" "$CLAUDE_AGENTS/$name"
  done
fi

# Remove snyk symlinks that we want Bastian's version to supersede.
for name in "${OVERRIDDEN_SNYK_SKILLS[@]}"; do
  for root in "$CLAUDE_SKILLS" "$CURSOR_SKILLS"; do
    dst="$root/$name"
    if [ -L "$dst" ]; then
      rm "$dst"
      REMOVED=$((REMOVED + 1))
      log "remove: $dst (overridden by bastian)"
    fi
  done
done

[ "$SUMMARY" = "1" ] && printf 'external-skills-sync: linked=%d skipped=%d removed=%d\n' "$LINKED" "$SKIPPED" "$REMOVED" >&2
exit 0
