#!/usr/bin/env bash
# Sync snyk/bastis-harness into ~/.claude as symlinks.
# Precedence: snyk/ide-tools wins (run ide-tools-sync first).
# A skill/agent/hook is only linked if no target with that name already exists.
# Runs after ide-tools-sync, before external-skills-sync (personal preview).
#
# Layout (bastis-harness):
#   skills/<name>/SKILL.md   -> ~/.claude/skills/<name> + ~/.cursor/skills/<name>
#   agents/<name>.md         -> ~/.claude/agents/<name>.md
#   hooks/<name>.{sh,py}     -> ~/.claude/hooks/<name>
#
# Env:
#   BASTIS_HARNESS_REPO        path to clone (default: ~/repos/bastis-harness)
#   BASTIS_HARNESS_SYNC_PULL=0 skip the git pull step (default: 1 = pull)
#   BASTIS_HARNESS_SYNC_VERBOSE=1  log every link/skip
#   BASTIS_HARNESS_SYNC_SUMMARY=0  suppress the summary line

set -u

REPO="${BASTIS_HARNESS_REPO:-$HOME/repos/bastis-harness}"
CLAUDE_SKILLS="$HOME/.claude/skills"
CURSOR_SKILLS="$HOME/.cursor/skills"
CLAUDE_AGENTS="$HOME/.claude/agents"
CLAUDE_HOOKS="$HOME/.claude/hooks"

VERBOSE="${BASTIS_HARNESS_SYNC_VERBOSE:-0}"
SUMMARY="${BASTIS_HARNESS_SYNC_SUMMARY:-1}"
LINKED=0
SKIPPED=0

log()  { [ "$VERBOSE" = "1" ] && printf '%s\n' "$*" >&2; return 0; }
warn() { printf 'bastis-harness-sync: %s\n' "$*" >&2; }

[ -d "$REPO" ] || { warn "missing $REPO — clone snyk/bastis-harness there first"; exit 0; }

if [ "${BASTIS_HARNESS_SYNC_PULL:-1}" = "1" ] && [ -e "$REPO/.git" ]; then
  if git -C "$REPO" pull --ff-only --quiet 2>/dev/null; then
    log "pulled latest in $REPO"
  else
    log "pull skipped or failed in $REPO (offline, dirty tree, or non-ff)"
  fi
fi

mkdir -p "$CLAUDE_SKILLS" "$CURSOR_SKILLS" "$CLAUDE_AGENTS" "$CLAUDE_HOOKS"

# link_one <src> <dst>
# Symlink src -> dst only if dst doesn't already exist (any symlink or real file wins).
link_one() {
  local src="$1" dst="$2"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    log "skip:  $dst (already exists)"
    SKIPPED=$((SKIPPED + 1))
    return 0
  fi
  ln -s "$src" "$dst"
  LINKED=$((LINKED + 1))
  log "link:  $dst -> $src"
}

# Skills (Claude + Cursor)
if [ -d "$REPO/skills" ]; then
  for d in "$REPO/skills"/*/; do
    [ -d "$d" ] || continue
    [ -f "${d}SKILL.md" ] || continue
    name="$(basename "${d%/}")"
    link_one "${d%/}" "$CLAUDE_SKILLS/$name"
    link_one "${d%/}" "$CURSOR_SKILLS/$name"
  done
fi

# Agents (Claude only)
if [ -d "$REPO/agents" ]; then
  for f in "$REPO/agents"/*.md; do
    [ -f "$f" ] || continue
    name="$(basename "$f")"
    link_one "$f" "$CLAUDE_AGENTS/$name"
  done
fi

# Hooks (Claude only)
if [ -d "$REPO/hooks" ]; then
  for f in "$REPO/hooks"/*.sh "$REPO/hooks"/*.py; do
    [ -f "$f" ] || continue
    [ -x "$f" ] || warn "hook not executable (chmod +x): $f"
    name="$(basename "$f")"
    link_one "$f" "$CLAUDE_HOOKS/$name"
  done
fi

[ "$SUMMARY" = "1" ] && printf 'bastis-harness: linked=%d skipped=%d\n' "$LINKED" "$SKIPPED" >&2
exit 0
