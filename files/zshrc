# =============================================================================
# Homebrew & shell
# =============================================================================
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="/usr/local/bin:$PATH"
export SHELL="$(command -v zsh)"

# =============================================================================
# Oh My Zsh — https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
# =============================================================================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"

plugins=(
  aliases
  autojump
  colorize
  dircycle
  git
  history
  screen
  zoxide
)

source "$ZSH/oh-my-zsh.sh"

# =============================================================================
# History
# =============================================================================
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=1000000000
export SAVEHIST=1000000000
setopt EXTENDED_HISTORY

# =============================================================================
# Node: fnm (primary) & nvm
# =============================================================================
export PATH="$HOME/.fnm:$PATH"
eval "$(fnm env)"

export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

# =============================================================================
# Go
# =============================================================================
unset GOROOT
[ -d "/opt/homebrew/opt/go/libexec" ] && export GOROOT="/opt/homebrew/opt/go/libexec"
export GOPATH="${GOPATH:-$HOME/go}"
export PATH="$PATH:$GOPATH/bin"

# =============================================================================
# PATH — tools & CLIs (order: project tools → user → npm → apps)
# =============================================================================
export PATH="/Users/skippy/repos/snyk-ls/.bin/pact/bin:$PATH"
export PATH="$PATH:/Users/skippy/tools"
# Do not use $(npm config get prefix) here — it runs npm/node on every login and
# triggers macOS privacy prompts. Homebrew shellenv + fnm already put global bins on PATH.
export PATH="$HOME/.local/bin:$PATH"
export PATH="/Users/skippy/.cargo/bin:$PATH"
export PATH="/Users/skippy/.codeium/windsurf/bin:$PATH"

# Google Cloud SDK
if [ -f '/Users/skippy/Downloads/google-cloud-sdk/path.zsh.inc' ]; then
  . '/Users/skippy/Downloads/google-cloud-sdk/path.zsh.inc'
fi
if [ -f '/Users/skippy/Downloads/google-cloud-sdk/completion.zsh.inc' ]; then
  . '/Users/skippy/Downloads/google-cloud-sdk/completion.zsh.inc'
fi

# =============================================================================
# Aliases
# =============================================================================
alias k='kubectl'
alias sk="/Users/skippy/repos/skippy/target/release/skippy"
alias snyk='/Users/skippy/repos/cli/binary-releases/snyk-macos-arm64'
alias my="/Users/skippy/repos/prtracker/target/release/my-prs"
alias tm='task-master'
alias taskmaster='task-master'
alias hamster='task-master'
alias ham='task-master'
alias start="/Users/skippy/repos/start/target/debug/start"

# =============================================================================
# Claude starter — print a skills cheatsheet before launching `claude`.
# Silence with CLAUDE_STARTER_QUIET=1.
# =============================================================================
claude() {
  if [ -z "$CLAUDE_STARTER_QUIET" ]; then
    local skills_dir="$HOME/repos/ide-tools/Agent-skills"
    print "\e[36m━━ Claude — skills from ide-tools ━━\e[0m"
    print ""
    if [ -d "$skills_dir" ]; then
      local -a skills; local d
      for d in "$skills_dir"/*/SKILL.md(N); do
        skills+=("/${d:h:t}")
      done
      if (( ${#skills} > 0 )); then
        print -C 4 -- $skills
      else
        print "  (no skills found in $skills_dir)"
      fi
    else
      print "  (ide-tools not at $skills_dir)"
    fi
    print ""
    print "\e[90m  silence: CLAUDE_STARTER_QUIET=1\e[0m"
  fi
  command claude "$@"
}

# ============================================================                                                                                                                                                                                                                                                                                                                                                                                                                                           =================
# Other profiles
