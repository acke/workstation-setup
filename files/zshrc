gpgconf --launch gpg-agent
[ -f ~/.ssh/snyk ] && ssh-add -q ~/.ssh/snyk 2>/dev/null

# =============================================================================
# Snyk internal — secrets read from macOS Keychain
#   Store with: read -s VAR && security add-generic-password -a "$USER" -s NAME -w "$VAR" && unset VAR
# =============================================================================
export SNYK_TOKEN="$(security find-generic-password -a "$USER" -s SNYK_TOKEN -w 2>/dev/null)"
export SNYK_INTERNAL_PROXY_CREDENTIALS="$(security find-generic-password -a "$USER" -s SNYK_INTERNAL_PROXY_CREDENTIALS -w 2>/dev/null)"
export SNYK_INTERNAL_BROKER_CREDENTIALS="$(security find-generic-password -a "$USER" -s SNYK_INTERNAL_BROKER_CREDENTIALS -w 2>/dev/null)"
export SNYK_INTERNAL_PROXY_HOST='proxy.dev16.us-east1.snyk-main.gcp.snyk-internal.net'

# =============================================================================
# Local overrides (e.g. sdkman in ~/.zshrc.local)
# =============================================================================
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
export PATH="$HOME/Documents/commercial/ide-tools/cli:$PATH"
export PATH="$HOME/repos/ide-tools/cli:$PATH"
export PATH="$HOME/repos/workstation-setup/scripts/custom/sync:$PATH"

# =============================================================================
# Daily sync — runs once per calendar day (first shell start only).
# Force a re-run any time: touch -t 000101010000 ~/.cache/daily-sync-stamp
# =============================================================================
_SYNC_STAMP="$HOME/.cache/daily-sync-stamp"
if [[ "$(cat "$_SYNC_STAMP" 2>/dev/null)" != "$(date +%Y-%m-%d)" ]]; then
  SYNC_DIR="$HOME/repos/workstation-setup/scripts/custom/sync"
  [ -x "$SYNC_DIR/ide-tools-sync" ]            && "$SYNC_DIR/ide-tools-sync"
  [ -x "$SYNC_DIR/bastis-harness-sync" ]       && "$SYNC_DIR/bastis-harness-sync"
  [ -x "$SYNC_DIR/external-skills-sync" ]      && "$SYNC_DIR/external-skills-sync"
  [ -x "$SYNC_DIR/claude-marketplaces-sync" ]  && "$SYNC_DIR/claude-marketplaces-sync"
  [ -x "$SYNC_DIR/bastis-dev-container-sync" ] && "$SYNC_DIR/bastis-dev-container-sync"
  date +%Y-%m-%d > "$_SYNC_STAMP"
  unset SYNC_DIR
fi
unset _SYNC_STAMP

# =============================================================================
# tmux — auto-start on new shell.
# When launched from Warp, prime the new tmux session with WARP_STARTER_SHOW
# so the inner shell prints the Warp surface reminder (block below).
# WARP_STARTER_QUIET=1 disables the reminder.
# =============================================================================
if [ -z "$TMUX" ] && [ "$TERM_PROGRAM" != "WarpTerminal" ]; then
  exec tmux new-session
fi

# =============================================================================
# Warp surface starter — print inside the new tmux session, then clear the
# session-env flag so subsequent panes/windows don't re-trigger.
# =============================================================================
if [ -n "$TMUX" ] && [ -n "$WARP_STARTER_SHOW" ]; then
  # Clear the session-env flag FIRST so a pane/window split before this shell
  # finishes printing doesn't inherit the flag and re-trigger.
  tmux set-environment -u WARP_STARTER_SHOW
  unset WARP_STARTER_SHOW
  print "\e[36m━━ Warp — pick the right surface before you start ━━\e[0m"
  print ""
  print "  \e[33mWindow\e[0m    (Cmd+N)    separate project / context switch"
  print ""
  print "  \e[33mTab\e[0m       (Cmd+T)    new shell, same project"
  print ""
  print "  \e[33mPane\e[0m      (Cmd+D)    parallel work in same context (logs + tests + edit)"
  print ""
  print "  \e[33mSession\e[0m   (Cmd+P)    saved launch config / preset layout"
  print ""
fi

# OSC 133 prompt marker — lets tmux jump between prompts in scrollback
# (C-b P / C-b N, or K/J in copy mode). See files/tmux.conf.
_osc133_prompt_start() { print -Pn '\e]133;A\e\\' }
precmd_functions+=(_osc133_prompt_start)

# =============================================================================
# Line-editing keybindings — needed inside tmux where Warp's editor doesn't apply.
# In Warp, rebind: Cmd+Backspace -> ^U, Cmd+Left -> ^A, Cmd+Right -> ^E,
#                  Opt+Backspace -> ^[^?, Opt+Left -> ^[b, Opt+Right -> ^[f.
# =============================================================================
bindkey "^[^?" backward-kill-word     # Opt+Backspace: delete word left
bindkey "^W"   backward-kill-word     # Ctrl+W
bindkey "^U"   backward-kill-line     # Ctrl+U / Cmd+Backspace: delete to line start
bindkey "^[b"  backward-word          # Opt+Left
bindkey "^[f"  forward-word           # Opt+Right
bindkey "^A"   beginning-of-line      # Ctrl+A / Cmd+Left
bindkey "^E"   end-of-line            # Ctrl+E / Cmd+Right
