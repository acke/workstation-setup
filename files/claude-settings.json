{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git tag:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(jq:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(which:*)",
      "Bash(npm:*)",
      "Bash(make:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(pip:*)",
      "Bash(cargo:*)",
      "Bash(go:*)",
      "Bash(tee:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(test:*)",
      "Bash(/usr/bin/grep:*)",
      "Bash(/usr/bin/find:*)",
      "Bash(/usr/bin/sed:*)",
      "Bash(/usr/bin/awk:*)",
      "Bash(/bin/cat:*)",
      "Bash(/bin/ls:*)",
      "Bash(/usr/bin/head:*)",
      "Bash(/usr/bin/tail:*)"
    ],
    "deny": [
      "Bash(rm -rf /)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$HOME/.claude/brain\" pull --rebase --autostash --quiet origin main >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-push.sh",
            "if": "Bash(git push*)",
            "timeout": 600,
            "statusMessage": "Running make pre-push"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "skill-usage@snyk-internal": true
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "proxy.golang.org",
        "sum.golang.org",
        "golang.org",
        "go.dev",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ],
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/Users/skippy/.cache",
        "/Users/skippy/Library/Caches",
        "/Users/skippy/.local/share",
        "/Users/skippy/.local/state",
        "/Users/skippy/go",
        "/Users/skippy/.cargo/registry",
        "/Users/skippy/.cargo/git",
        "/Users/skippy/.npm",
        "/Users/skippy/.yarn",
        "/Users/skippy/.pnpm-store",
        "/Users/skippy/.bun",
        "/Users/skippy/.asdf/installs",
        "/Users/skippy/.asdf/shims",
        "/Users/skippy/.asdf/plugins",
        "/Users/skippy/.claude/brain"
      ],
      "denyWrite": [
        "/Users/skippy/.ssh",
        "/Users/skippy/.aws",
        "/Users/skippy/.gnupg",
        "/Users/skippy/.config/gh/hosts.yml",
        "/Users/skippy/.zsh_history",
        "/Users/skippy/.bash_history",
        "/Users/skippy/.npmrc",
        "/Users/skippy/.yarnrc",
        "/Users/skippy/.yarnrc.yml",
        "/Users/skippy/.pypirc",
        "/Users/skippy/.netrc",
        "/Users/skippy/.docker/config.json",
        "/Users/skippy/.kube/config",
        "/Users/skippy/.cargo/credentials.toml",
        "/Users/skippy/Library/Application Support/Google/Chrome",
        "/Users/skippy/Library/Application Support/Firefox",
        "/Users/skippy/Library/Cookies",
        "/Users/skippy/Library/Keychains",
        "/Users/skippy/Library/Mail",
        "/Users/skippy/Library/Messages"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "git",
      "gh"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "theme": "auto",
  "editorMode": "vim",
  "preferredNotifChannel": "iterm2_with_bell"
}
